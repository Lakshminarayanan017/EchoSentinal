# Normalize line endings: LF in the repo, native on checkout where it matters.
* text=auto
*.py text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.ipynb text eol=lf

# Binary
*.wav binary
*.mp3 binary
*.png binary
*.pt binary
*.pth binary
